# Banco de dados
DATABASE_URL=postgresql://mediddata:mediddata@localhost:5432/mediddata

# Redis
REDIS_URL=redis://localhost:6379/0

# Segurança — alterar obrigatoriamente em produção
SECRET_KEY=troque-esta-chave-em-producao-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Ambiente
ENVIRONMENT=development

# Dados
DADOS_DIR=./dados

# Workers uvicorn (produção: 2-4)
WORKERS=1
